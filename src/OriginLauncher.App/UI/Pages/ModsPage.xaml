<UserControl x:Class="OriginLauncher.App.UI.Pages.ModsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <!-- Left margin (80) clears the floating left-edge icon column, matching
         SettingsPage. Scrollbar hidden (wheel still works) — same convention. -->
    <ScrollViewer Margin="80,16,32,20" VerticalScrollBarVisibility="Hidden">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource ScrollBar.Minimal}"/>
        </ScrollViewer.Resources>

        <StackPanel MaxWidth="640" HorizontalAlignment="Left">

            <!-- Header -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Mods" Style="{StaticResource Text.H1}"/>
                <Border Grid.Column="1" x:Name="VersionChip" VerticalAlignment="Center"
                        Background="{StaticResource Brush.Panel}"
                        BorderBrush="{StaticResource Brush.SoftStroke}" BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Chip}" Padding="10,4">
                    <TextBlock x:Name="VersionChipText" Text="—" Style="{StaticResource Text.BodyDim}"/>
                </Border>
            </Grid>
            <TextBlock Text="Import your own mods for this version. Each version keeps its own set — switching versions on Home swaps this list to match."
                       Style="{StaticResource Text.BodyDim}" TextWrapping="Wrap" Margin="0,0,0,16"/>

            <!-- Drop zone: drag .jar files in, or click to open the mods folder -->
            <Border x:Name="DropZone" AllowDrop="True" Cursor="Hand"
                    Background="{StaticResource Brush.Panel}"
                    BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1.5"
                    CornerRadius="{StaticResource Radius.Card}"
                    Padding="24" Margin="0,0,0,20"
                    MouseLeftButtonUp="DropZone_Click"
                    DragEnter="DropZone_DragEnter" DragOver="DropZone_DragEnter"
                    DragLeave="DropZone_DragLeave" Drop="DropZone_Drop">
                <StackPanel HorizontalAlignment="Center">
                    <Path Data="{StaticResource Icon.Folder}" Style="{StaticResource Icon.Base}"
                          Width="34" Height="34" Stroke="{StaticResource Brush.TextDim}"
                          HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Drag &amp; drop .jar mods here"
                               Style="{StaticResource Text.Body}" HorizontalAlignment="Center"/>
                    <TextBlock Text="or click to open the mods folder"
                               Style="{StaticResource Text.BodyDim}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Status line (import errors, "close Minecraft first", etc.) -->
            <TextBlock x:Name="StatusText" Style="{StaticResource Text.BodyDim}" TextWrapping="Wrap"
                       Visibility="Collapsed" Margin="0,0,0,12"/>

            <!-- Your mods -->
            <TextBlock Text="YOUR MODS" Style="{StaticResource Text.Eyebrow}" Margin="2,0,0,8"/>
            <StackPanel x:Name="UserModsPanel"/>
            <TextBlock x:Name="UserEmptyState"
                       Text="No mods yet — drag a .jar above to add one."
                       Style="{StaticResource Text.BodyDim}" Margin="2,2,0,0"/>

            <!-- Built-in (Origin-managed, read-only) -->
            <StackPanel x:Name="BuiltInSection" Visibility="Collapsed" Margin="0,20,0,0">
                <TextBlock Text="BUILT-IN" Style="{StaticResource Text.Eyebrow}" Margin="2,0,0,8"/>
                <TextBlock Text="Installed and kept up to date by Origin — always on."
                           Style="{StaticResource Text.BodyDim}" Margin="2,0,0,8"/>
                <StackPanel x:Name="BuiltInPanel"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
