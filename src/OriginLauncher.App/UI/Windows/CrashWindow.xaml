<Window x:Class="OriginLauncher.App.UI.Windows.CrashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Origin Launcher — Error"
        Width="660" Height="560" MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterScreen"
        Background="#FF121212"
        FontFamily="Bahnschrift, Segoe UI Variable Text, Segoe UI">

    <!-- Self-contained styling (hardcoded, no theme StaticResources): a crash
         dialog must render even if something in the app's resources is the very
         thing that broke. -->
    <Window.Resources>
        <Style x:Key="CrashButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="Background" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7" SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FF505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CrashButtonPrimary" TargetType="Button" BasedOn="{StaticResource CrashButton}">
            <Setter Property="Background" Value="#FFE0E0E0"/>
            <Setter Property="Foreground" Value="#FF121212"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7" SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#FFEDEDED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="Heading" Text="Origin Launcher ran into a problem"
                   Foreground="#FFE0E0E0" FontSize="22" FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1" x:Name="Summary" Foreground="#FFB0B0B0" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="Something went wrong. The details below explain exactly what happened — click Copy details to put them on your clipboard, then paste them into a search or send them along so it can be fixed."/>

        <Border Grid.Row="2" Margin="0,16,0,0" Background="#FF1A1A1A" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="7">
            <TextBox x:Name="DetailsBox" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                     Background="Transparent" Foreground="#FFE0E0E0" BorderThickness="0"
                     FontFamily="Consolas, Cascadia Mono, Courier New" FontSize="12" Padding="12"
                     TextWrapping="NoWrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </Border>

        <TextBlock Grid.Row="3" x:Name="SavedTo" Foreground="#FF888888" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CopyButton" Content="Copy details" Style="{StaticResource CrashButton}" Margin="0,0,8,0" Click="Copy_Click"/>
            <Button x:Name="CloseButton" Content="Close" Style="{StaticResource CrashButtonPrimary}" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
