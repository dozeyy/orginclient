<UserControl x:Class="OriginLauncher.App.UI.Controls.VersionSelectOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Visibility="Collapsed" Focusable="True">

    <UserControl.Resources>

        <!-- A card is a ListBoxItem: selection-on-click is built in and reliable,
             which a Border+MouseLeftButtonUp was not. The item chrome is stripped;
             the DataTemplate paints the whole card. -->
        <Style x:Key="CardItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Big grid card (3x3 landing) -->
        <DataTemplate x:Key="GridCardTemplate">
            <Grid x:Name="CardRoot" Width="300" Height="188" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Grid.RenderTransform>
                <Border CornerRadius="{StaticResource Radius.Card}">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding ImagePath}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
                <!-- Neutral-gray wash used to "gray out" coming-soon cards. -->
                <Border x:Name="GrayVeil" CornerRadius="{StaticResource Radius.Card}" Opacity="0">
                    <Border.Background>
                        <SolidColorBrush Color="#8C8C8C"/>
                    </Border.Background>
                </Border>
                <Border CornerRadius="{StaticResource Radius.Card}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00121212" Offset="0.45"/>
                            <GradientStop Color="#D9121212" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Border x:Name="Ring" CornerRadius="{StaticResource Radius.Card}" BorderThickness="2"
                        BorderBrush="{StaticResource Brush.Accent}" Opacity="0"/>
                <Border CornerRadius="{StaticResource Radius.Card}" BorderThickness="1"
                        BorderBrush="{StaticResource Brush.SoftStroke}"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource Text.H2}"
                           VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="14,0,14,12"/>
                <Border x:Name="Chip" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10"
                        Padding="8,4" Visibility="Collapsed" Background="#CC1A1A1A"
                        CornerRadius="{StaticResource Radius.Chip}" BorderThickness="1" BorderBrush="{StaticResource Brush.Stroke}">
                    <TextBlock Text="COMING SOON" Style="{StaticResource Text.Eyebrow}"/>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding AnySupported}" Value="False">
                    <Setter TargetName="Chip" Property="Visibility" Value="Visible"/>
                    <!-- Gray out coming-soon cards so they read as unavailable. -->
                    <Setter TargetName="GrayVeil" Property="Opacity" Value="0.45"/>
                    <Setter TargetName="CardRoot" Property="Opacity" Value="0.72"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="Ring" Property="Opacity" Value="0.6"/>
                    <Setter TargetName="CardRoot" Property="Opacity" Value="1"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Compact left-stack card (detail view) -->
        <DataTemplate x:Key="StackCardTemplate">
            <Grid x:Name="StackRoot" Height="58">
                <Border CornerRadius="{StaticResource Radius.NavItem}">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding ImagePath}" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
                <Border x:Name="StackGray" CornerRadius="{StaticResource Radius.NavItem}" Opacity="0">
                    <Border.Background>
                        <SolidColorBrush Color="#8C8C8C"/>
                    </Border.Background>
                </Border>
                <Border CornerRadius="{StaticResource Radius.NavItem}" Background="#A6121212"/>
                <Border x:Name="SelRing" CornerRadius="{StaticResource Radius.NavItem}" BorderThickness="2"
                        BorderBrush="{StaticResource Brush.Accent}" Opacity="0"/>
                <TextBlock Text="{Binding Title}" Style="{StaticResource Text.Body}" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="12,0"/>
                <Border x:Name="MiniChip" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"
                        Visibility="Collapsed">
                    <TextBlock Text="SOON" Style="{StaticResource Text.Eyebrow}"/>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding AnySupported}" Value="False">
                    <Setter TargetName="MiniChip" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="StackGray" Property="Opacity" Value="0.4"/>
                    <Setter TargetName="StackRoot" Property="Opacity" Value="0.72"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="SelRing" Property="Opacity" Value="1"/>
                    <Setter TargetName="StackRoot" Property="Opacity" Value="1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="SelRing" Property="Opacity" Value="0.5"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Small feature tag chip in the detail view -->
        <Style x:Key="DetailChip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Brush.Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource Radius.Chip}"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="Margin" Value="0,0,7,0"/>
        </Style>

        <!-- Version dropdown: unsupported entries disabled + tagged -->
        <Style x:Key="VersionItemContainer" TargetType="ComboBoxItem" BasedOn="{StaticResource Input.ComboBoxItem}">
            <Setter Property="IsEnabled" Value="{Binding Supported}"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="VersionItemTemplate">
            <Grid MinWidth="200">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Id}" Style="{StaticResource Text.Body}"/>
                <TextBlock x:Name="SoonTag" Grid.Column="1" Text="COMING SOON" Style="{StaticResource Text.Eyebrow}"
                           VerticalAlignment="Center" Visibility="Collapsed"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Supported}" Value="False">
                    <Setter TargetName="SoonTag" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource Brush.Bg}">
        <!-- Left inset clears the floating nav rail (Home/Mods/Settings icons). -->
        <Grid Margin="92,24,56,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="8,0,8,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Back-to-grid (only in detail view) -->
                <Button Grid.Column="0" x:Name="BackButton" Style="{StaticResource Button.Chrome}" Width="34" Height="34"
                        Padding="8" VerticalAlignment="Center" Margin="0,0,12,0" Visibility="Collapsed"
                        Click="Back_Click" ToolTip="All versions">
                    <Path Data="M6,1 L1,6 L6,11" Stroke="{StaticResource Brush.TextDim}" StrokeThickness="1.7"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Width="7" Height="12" Stretch="Uniform"/>
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="CHOOSE YOUR VERSION" Style="{StaticResource Text.Eyebrow}"/>
                    <TextBlock Text="Select a version" Style="{StaticResource Text.H1}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" Style="{StaticResource Button.Chrome}" Width="34" Height="34" Padding="8"
                        VerticalAlignment="Center" Click="Close_Click" ToolTip="Close">
                    <Path Data="{StaticResource Icon.Close}" Style="{StaticResource Icon.Base}"
                          Width="14" Height="14" Stroke="{StaticResource Brush.TextDim}"/>
                </Button>
            </Grid>

            <!-- ===== GRID STATE ===== -->
            <Viewbox Grid.Row="1" x:Name="GridState" Stretch="Uniform" StretchDirection="DownOnly"
                     MaxWidth="1040" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ListBox x:Name="GridList" Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource CardItem}"
                         ItemTemplate="{StaticResource GridCardTemplate}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         SelectionChanged="GridList_SelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="3" Columns="3"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Viewbox>

            <!-- ===== DETAIL STATE ===== -->
            <Grid Grid.Row="1" x:Name="DetailState" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="DetailSlide" X="0"/>
                </Grid.RenderTransform>

                <!-- Left: stacked cards, newest at top -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,8,0">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ScrollBar.Minimal}"/>
                    </ScrollViewer.Resources>
                    <ListBox x:Name="StackList" Background="Transparent" BorderThickness="0"
                             ItemTemplate="{StaticResource StackCardTemplate}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="StackList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource CardItem}">
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>

                <!-- Right: the selected family's detail -->
                <Grid Grid.Column="1" x:Name="DetailPanel" Margin="36,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top: compact hero + headline info -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Smaller, crisp hero image -->
                        <Border Grid.Column="0" Width="360" Height="225" CornerRadius="{StaticResource Radius.Card}" ClipToBounds="True">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding ImagePath}" Stretch="UniformToFill"/>
                            </Border.Background>
                            <Border CornerRadius="{StaticResource Radius.Card}" BorderThickness="1" BorderBrush="{StaticResource Brush.SoftStroke}"/>
                        </Border>

                        <!-- Headline info -->
                        <StackPanel Grid.Column="1" Margin="24,4,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Tagline}" Style="{StaticResource Text.Eyebrow}"
                                       Foreground="{StaticResource Brush.TextDim}"/>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource Text.H1}" Margin="0,2,0,0"/>
                            <TextBlock x:Name="FactsText" Style="{StaticResource Text.BodyDim}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <StackPanel x:Name="ChipsPanel" Orientation="Horizontal" Margin="0,14,0,0">
                                <Border Style="{StaticResource DetailChip}"><TextBlock Text="ORIGIN UI" Style="{StaticResource Text.Eyebrow}"/></Border>
                                <Border Style="{StaticResource DetailChip}"><TextBlock Text="PERFORMANCE MODS" Style="{StaticResource Text.Eyebrow}"/></Border>
                                <Border Style="{StaticResource DetailChip}"><TextBlock Text="IRIS SHADERS" Style="{StaticResource Text.Eyebrow}"/></Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Description -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,22,0,0">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ScrollBar.Minimal}"/>
                        </ScrollViewer.Resources>
                        <StackPanel>
                            <TextBlock Text="ABOUT THIS UPDATE" Style="{StaticResource Text.Eyebrow}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Description}" Style="{StaticResource Text.Body}"
                                       Foreground="{StaticResource Brush.TextDim}" FontSize="14" LineHeight="22"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <TextBlock x:Name="ComingSoonNote" Text="No playable Origin build for this version yet — it's coming soon."
                                   Style="{StaticResource Text.Body}" Foreground="{StaticResource Brush.TextMuted}"
                                   Margin="0,0,0,12" Visibility="Collapsed"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Bottom">
                                <TextBlock Text="VERSION" Style="{StaticResource Text.Eyebrow}" Margin="0,0,0,6"/>
                                <ComboBox x:Name="VersionDropdown" MinWidth="190" MinHeight="46" FontSize="15"
                                          ItemContainerStyle="{StaticResource VersionItemContainer}"
                                          ItemTemplate="{StaticResource VersionItemTemplate}"
                                          SelectionChanged="VersionDropdown_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left">
                                <Button x:Name="LaunchButton" Content="LAUNCH" Style="{StaticResource Button.Primary}"
                                        FontSize="16" Padding="52,15" Margin="0,0,12,0" Click="Launch_Click"/>
                                <Button x:Name="ModsButton" Content="MODS" Style="{StaticResource Button.Secondary}"
                                        FontSize="16" Padding="36,15" Click="Mods_Click"
                                        ToolTip="Open this version's mods folder to add your own mods"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
